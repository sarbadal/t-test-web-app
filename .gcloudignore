# Cloud Function deployment ignore file.

# Exclude source control
.git/
.gitignore
.gcloudignore

# Exclude Python build artifacts
**/__pycache__/
**/*.py[cod]
**/*.pyo
**/*.pyd

# Exclude local environment files
.env
.env.prod
.venv/
env/
venv/

# Exclude local project artifacts and noise
deployment.sh
programmatic_api_call.py
sample_data/
tests/
db_init.py

# Ensure required files are included
!main.py
!requirements.txt
!deployment.py
!src/
!src/instance/
!src/instance/ttest_analysis.db
